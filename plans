// ════════════════════════════════════════
function showTab(tab){
  // Hide all
  ['stats','workout','meal','account'].forEach(function(t){
    document.getElementById('sc-'+t).className='sc';
    document.getElementById('nav-'+t).classList.remove('on');
  });
  // Show selected
  document.getElementById('sc-'+tab).className='sc in';
  document.getElementById('nav-'+tab).classList.add('on');
  currentTab = tab;

  // Build content if needed
  if(tab==='stats')   buildStatsTab();
  if(tab==='workout') buildWorkoutTab();
  if(tab==='meal')    buildMealTab();
  if(tab==='account') buildAccountTab();
}

function goBack(){
  // On this standalone page, just go back to stats
  if(currentTab!=='stats') showTab('stats');
  else window.location.href='index.html';
}

// ════════════════════════════════════════
//  AUTH
// ════════════════════════════════════════
function switchTab(tab){
  document.getElementById('loginForm').style.display  = tab==='login'  ? 'block':'none';
  document.getElementById('signupForm').style.display = tab==='signup' ? 'block':'none';
  document.getElementById('tabLogin').classList.toggle('active',  tab==='login');
  document.getElementById('tabSignup').classList.toggle('active', tab==='signup');
  document.getElementById('authErr').style.display='none';
}

function showAuthErr(msg){
  var el=document.getElementById('authErr');
  el.textContent=msg; el.style.display=msg?'block':'none';
}

function doLogin(){
  var email = document.getElementById('loginEmail').value.trim().toLowerCase();
  var pass  = document.getElementById('loginPass').value;
  if(!email||!pass){showAuthErr('Please fill in all fields.');return;}
  var users = getUsers();
  if(users[email] && users[email].password===btoa(pass)){
    loginSuccess(users[email]);
  } else if(email==='dev@getphysiq.fit'&&pass==='physiq2025dev'){
    loginSuccess({email:'dev@getphysiq.fit',name:'Developer',role:'dev'});
  } else {
    showAuthErr('Incorrect email or password.');
  }
}

function doSignup(){
  var name  = document.getElementById('signupName').value.trim();
  var email = document.getElementById('signupEmail').value.trim().toLowerCase();
  var pass  = document.getElementById('signupPass').value;
  if(!name||!email||!pass){showAuthErr('Please fill in all fields.');return;}
  if(pass.length<6){showAuthErr('Password must be at least 6 characters.');return;}
  var users = getUsers();
  if(users[email]){showAuthErr('Account already exists. Please log in.');return;}
  var newUser={email,name,password:btoa(pass),role:'user',created:Date.now()};
  users[email]=newUser; saveUsers(users);
  loginSuccess(newUser);
}

function loginSuccess(user){
  saveSession(user);
  document.getElementById('authWall').style.display='none';
  setupUserUI(user);
  init();
}

function doLogout(){
  clearSession();
  document.getElementById('userMenu').style.display='none';
  document.getElementById('avatarBtn').style.display='none';
  document.getElementById('authWall').style.display='flex';
}

function setupUserUI(user){
  var avatar = document.getElementById('avatarBtn');
  avatar.style.display='flex';
  avatar.textContent=user.name.charAt(0).toUpperCase();
  document.getElementById('menuName').textContent=user.name;
}

function toggleMenu(){
  var m=document.getElementById('userMenu');
  m.style.display=m.style.display==='block'?'none':'block';
  if(m.style.display==='block'){
    setTimeout(function(){
      document.addEventListener('click',function close(e){
        if(!m.contains(e.target)&&e.target.id!=='avatarBtn'){
          m.style.display='none';
          document.removeEventListener('click',close);
        }
      });
    },50);
  }
}

// ════════════════════════════════════════
//  NO QUIZ DATA SCREEN
// ════════════════════════════════════════
function showNoData(){
  var d = document.getElementById('sc-stats');
  d.innerHTML = `<div class="no-data">
    <div class="no-data-icon">📋</div>
    <div class="no-data-title">No Quiz Data Found</div>
    <div class="no-data-sub">Complete the GetPhysIQ quiz first so we can generate your personalised plans.</div>
    <button class="cta" onclick="window.location.href='index.html'">Take the Quiz →</button>
  </div>`;
  document.getElementById('sc-stats').className='sc in';
}

// ════════════════════════════════════════
//  INIT
// ════════════════════════════════════════
function init(){
  var quizData = localStorage.getItem('gp_quiz_state');
  if(!quizData){
    showNoData();
    return;
  }
  S = JSON.parse(quizData);
  workoutGenerated = false;
  mealGenerated    = false;
  buildStatsTab();
  buildAccountTab();
}

// ── Startup ──
var _sess = getSession();

// Handle autologin from email link
var _plParams = new URLSearchParams(window.location.search);
if(_plParams.get('autologin')==='1'){
  var _plEmail  = decodeURIComponent(_plParams.get('e')||'');
  var _plPass   = decodeURIComponent(_plParams.get('p')||'');
  var _plPlan   = decodeURIComponent(_plParams.get('plan')||'complete');
  var _plPeriod = decodeURIComponent(_plParams.get('period')||'monthly');
  window.history.replaceState({}, document.title, window.location.pathname);
  if(_plEmail && _plPass){
    var _plUsers = getUsers();
    if(!_plUsers[_plEmail]){
      _plUsers[_plEmail]={email:_plEmail,name:_plEmail.split('@')[0],password:btoa(_plPass),role:'user',created:Date.now()};
      saveUsers(_plUsers);
    }
    localStorage.setItem('gp_active_plan', JSON.stringify({plan:_plPlan,period:_plPeriod,email:_plEmail,unlocked:true,activatedAt:Date.now()}));
    var _plUser = _plUsers[_plEmail];
    saveSession(_plUser);
    setupUserUI(_plUser);
    init();
  }
} else if(_sess){
  setupUserUI(_sess);
  init();
} else {
  // No session — try to load plans anyway if quiz data exists (show locked state)
  var _hasQuiz = !!localStorage.getItem('gp_quiz_state');
  if(_hasQuiz){
    init();
  } else {
    document.getElementById('authWall').style.display='flex';
  }
}

// ── 5x logo tap = dev login ──
var _logoTapCount=0, _logoTapTimer=null;
document.querySelector('.logo').addEventListener('click', function(){
  _logoTapCount++;
  clearTimeout(_logoTapTimer);
  _logoTapTimer=setTimeout(function(){_logoTapCount=0;},1500);
  if(_logoTapCount>=5){
    _logoTapCount=0;
    var devUser={email:'dev@getphysiq.fit',name:'Developer',role:'dev',created:Date.now()};
    // Give dev full access
    localStorage.setItem('gp_active_plan',JSON.stringify({plan:'complete',period:'monthly',email:'dev@getphysiq.fit',unlocked:true}));
    saveSession(devUser);
    setupUserUI(devUser);
    document.getElementById('authWall').style.display='none';
    workoutGenerated=false; mealGenerated=false;
    init();
  }
});
</script>
