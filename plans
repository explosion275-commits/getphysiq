- Only output the HTML, no markdown`;

  try {
    var res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:2000,
        messages:[{role:'user',content:prompt}]
      })
    });
    var data = await res.json();
    var html = (data.content&&data.content[0]&&data.content[0].text)||'<p style="color:var(--muted)">Could not generate plan.</p>';
    var loading = document.getElementById('workout-loading');
    var content = document.getElementById('workout-content');
