<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"/>
<title>GetPhysIQ — My Plans</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --bg:#07070b;--s1:#0d0d12;--s2:#13131a;--s3:#1a1a24;
  --bdr:rgba(255,255,255,.07);--bdr2:rgba(255,255,255,.04);
  --blue:#5b8af0;--violet:#8b5cf6;--green:#10b981;--amber:#f59e0b;
  --red:#ef4444;--cyan:#06b6d4;--txt:#f2f2f8;--muted:#737380;--dim:#3a3a46;
}
html,body{height:100%;overflow:hidden;background:var(--bg);}
body{color:var(--txt);font-family:'Sora',sans-serif;-webkit-font-smoothing:antialiased;}
#app{width:100%;max-width:430px;height:100%;margin:0 auto;position:relative;overflow:hidden;background:var(--bg);}

/* ── TOPBAR ── */
#tb{position:fixed;top:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;padding:env(safe-area-inset-top,14px) 20px 0;z-index:300;display:flex;align-items:center;justify-content:space-between;background:linear-gradient(to bottom,rgba(7,7,11,.96) 65%,transparent);}
.logo{font-size:1.2rem;font-weight:800;letter-spacing:-.03em;background:linear-gradient(135deg,#fff 30%,rgba(255,255,255,.45));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
#bk{width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,.05);border:1px solid var(--bdr);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:.88rem;user-select:none;transition:background .2s;}
#bk:active{background:rgba(255,255,255,.12);}
.user-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--violet));display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:800;color:#fff;cursor:pointer;}

/* ── USER MENU ── */
#userMenu{position:fixed;top:56px;right:calc(50% - 195px);background:var(--s1);border:1px solid var(--bdr);border-radius:16px;padding:8px;z-index:500;width:200px;box-shadow:0 8px 32px rgba(0,0,0,.4);display:none;}
.menu-item{padding:11px 14px;border-radius:10px;font-size:.84rem;font-weight:600;cursor:pointer;transition:background .15s;display:flex;align-items:center;gap:10px;}
.menu-item:hover{background:var(--s2);}
.menu-item.danger{color:var(--red);}
.menu-sep{height:1px;background:var(--bdr);margin:4px 0;}

/* ── SCREENS ── */
.sc{position:absolute;inset:0;overflow-y:auto;overflow-x:hidden;opacity:0;pointer-events:none;padding-bottom:env(safe-area-inset-bottom,40px);}
.sc.in{pointer-events:all;animation:sIn .42s cubic-bezier(.16,1,.3,1) forwards;}
.sc.out{pointer-events:none;animation:sOut .3s ease-in forwards;}
@keyframes sIn{from{opacity:0;transform:translateX(46px)}to{opacity:1;transform:none}}
@keyframes sOut{from{opacity:1;transform:none}to{opacity:0;transform:translateX(-30px)}}

/* ── BOTTOM NAV ── */
#nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:rgba(7,7,11,.95);backdrop-filter:blur(20px);border-top:1px solid var(--bdr);display:flex;z-index:300;padding-bottom:env(safe-area-inset-bottom,0);}
.nav-btn{flex:1;padding:14px 0 12px;display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;border:none;background:none;color:var(--muted);font-family:'Sora',sans-serif;transition:color .18s;user-select:none;}
.nav-btn.on{color:var(--blue);}
.nav-icon{font-size:1.2rem;line-height:1;}
.nav-label{font-size:.6rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;}

/* ── STATS SECTION ── */
.res-top{padding:72px 20px 0;text-align:center;}
.res-top h1{font-size:2rem;font-weight:800;line-height:1.08;margin-bottom:6px;letter-spacing:-.04em;}
.res-top p{font-size:.82rem;color:var(--muted);}
.bmi-ring{width:160px;height:160px;margin:20px auto 8px;position:relative;display:flex;align-items:center;justify-content:center;}
.bmi-ring svg{position:absolute;inset:0;transform:rotate(-90deg);}
.bmi-inner{text-align:center;}
.bmi-num{font-size:2.3rem;font-weight:800;background:linear-gradient(135deg,var(--blue),var(--violet));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;}
.bmi-cat{font-size:.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;}
.scale-w{padding:0 20px;margin-bottom:6px;}
.scale-t{height:8px;border-radius:99px;background:linear-gradient(90deg,#5b8af0,#10b981,#f59e0b,#ef4444);position:relative;margin:9px 0 5px;}
.scale-th{position:absolute;top:50%;transform:translate(-50%,-50%);width:16px;height:16px;background:#fff;border-radius:50%;border:2.5px solid var(--blue);box-shadow:0 0 10px rgba(91,138,240,.7);transition:left 1.3s cubic-bezier(.4,0,.2,1);}
.scale-ll{display:flex;justify-content:space-between;font-size:.62rem;color:var(--muted);}
.ig{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:0 20px;margin:12px 0;}
.ib{background:var(--s1);border:1px solid var(--bdr);border-radius:12px;padding:12px 14px;}
.ibl{font-size:.66rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px;}
.ibv{font-size:1.7rem;font-weight:800;background:linear-gradient(135deg,var(--blue),var(--violet));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.05;}
.ibu{font-size:.7rem;color:var(--muted);}
.graph-card{margin:0 20px 14px;background:var(--s1);border:1px solid var(--bdr);border-radius:16px;padding:16px 14px;}
.graph-title{font-size:.82rem;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:6px;}
.pt{padding:0 20px;margin-bottom:16px;}
.pt h3{font-size:.66rem;color:var(--muted);text-transform:uppercase;letter-spacing:.09em;font-weight:700;margin-bottom:6px;}
.tag{display:inline-block;background:rgba(91,138,240,.1);border:1px solid rgba(91,138,240,.16);border-radius:6px;padding:4px 10px;font-size:.75rem;font-weight:600;color:var(--blue);margin:2px 3px 2px 0;}

/* ── PLAN TABS ── */
.plan-tab{flex:1;padding:11px 8px;border-radius:10px;border:1.5px solid var(--bdr);background:var(--s1);color:var(--muted);font-size:.82rem;font-weight:700;cursor:pointer;transition:all .18s;font-family:'Sora',sans-serif;}
.plan-tab.active{background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;border-color:transparent;box-shadow:0 4px 16px rgba(91,138,240,.3);}
.ai-card{margin:0 20px 16px;background:var(--s1);border:1px solid var(--bdr);border-radius:16px;overflow:hidden;min-height:120px;}
.ai-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;gap:14px;}
.ai-spinner{width:36px;height:36px;border-radius:50%;border:3px solid var(--bdr);border-top-color:var(--blue);animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
.ai-loading-text{font-size:.8rem;color:var(--muted);font-weight:500;text-align:center;}
.ai-error{padding:20px;text-align:center;color:var(--red);font-size:.85rem;}
.ai-content{padding:16px;}

/* ── WORKOUT PLAN ── */
.plan-week{display:flex;flex-direction:column;gap:12px;}
.plan-day{background:var(--s2);border-radius:12px;padding:14px;border:1px solid var(--bdr);}
.plan-rest{background:rgba(91,138,240,.05);border-radius:12px;padding:12px 14px;border:1px dashed var(--bdr);text-align:center;color:var(--muted);font-size:.82rem;font-weight:600;}
.plan-day-title{font-size:.88rem;font-weight:800;margin-bottom:10px;color:var(--txt);letter-spacing:-.02em;}
.plan-exercise{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--bdr2);font-size:.82rem;}
.plan-exercise:last-of-type{border-bottom:none;}
.plan-exercise-name{font-weight:600;color:var(--txt);}
.plan-exercise-sets{color:var(--blue);font-weight:700;font-size:.78rem;white-space:nowrap;margin-left:8px;}
.plan-note{margin-top:10px;padding:8px 12px;background:rgba(91,138,240,.08);border-left:3px solid var(--blue);border-radius:0 8px 8px 0;font-size:.76rem;color:var(--muted);line-height:1.5;}

/* ── MEAL PLAN ── */
.meal-macro-bar{display:flex;gap:8px;margin-bottom:14px;}
.macro-pill{flex:1;background:var(--s2);border-radius:10px;padding:10px 8px;text-align:center;border:1px solid var(--bdr);}
.macro-pill-val{font-size:1rem;font-weight:800;background:linear-gradient(135deg,var(--blue),var(--violet));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.macro-pill-lbl{font-size:.65rem;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-top:2px;}
.meal-section{background:var(--s2);border-radius:12px;padding:13px;margin-bottom:10px;border:1px solid var(--bdr);}
.meal-title{font-size:.88rem;font-weight:800;margin-bottom:9px;color:var(--txt);}
.meal-item{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--bdr2);font-size:.8rem;}
.meal-item:last-of-type{border-bottom:none;}
.meal-item-name{color:var(--txt);font-weight:500;}
.meal-item-cals{color:var(--muted);font-size:.74rem;white-space:nowrap;margin-left:6px;}
.meal-tip{margin-top:10px;padding:8px 12px;background:rgba(16,185,129,.08);border-left:3px solid var(--green);border-radius:0 8px 8px 0;font-size:.76rem;color:var(--muted);line-height:1.5;}
.meal-hydration{margin-top:10px;padding:10px 14px;background:rgba(6,182,212,.08);border-radius:10px;border:1px solid rgba(6,182,212,.2);font-size:.8rem;color:var(--cyan);font-weight:600;text-align:center;}

/* ── MY PLANS / ACCOUNT ── */
.myplans-wrap{padding:72px 20px 100px;}
.myplans-section{background:var(--s1);border:1px solid var(--bdr);border-radius:20px;padding:20px;margin-bottom:14px;}
.myplans-section-title{font-size:.68rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.09em;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.myplans-section-title::after{content:'';flex:1;height:1px;background:var(--bdr);}
.myplans-stat{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--bdr2);font-size:.84rem;}
.myplans-stat:last-child{border-bottom:none;}
.myplans-stat-label{color:var(--muted);font-weight:500;}
.myplans-stat-val{color:var(--txt);font-weight:700;}
.myplans-locked{text-align:center;padding:16px 0 4px;}
.myplans-locked-icon{font-size:2rem;margin-bottom:8px;}
.myplans-locked-title{font-size:.95rem;font-weight:800;margin-bottom:5px;}
.myplans-locked-sub{font-size:.76rem;color:var(--muted);line-height:1.6;margin-bottom:16px;}

/* ── CTA BUTTON ── */
.cta{background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;font-weight:700;font-size:.95rem;border:none;border-radius:50px;padding:18px;width:100%;cursor:pointer;box-shadow:0 8px 28px rgba(91,138,240,.32);transition:opacity .2s,transform .14s;font-family:'Sora',sans-serif;}
.cta:active{transform:scale(.98);}
.cta:disabled{opacity:.25;cursor:not-allowed;}

/* ── AUTH WALL ── */
#authWall{position:fixed;inset:0;background:var(--bg);z-index:9000;display:none;flex-direction:column;align-items:center;justify-content:center;padding:32px 28px;max-width:430px;margin:0 auto;left:50%;transform:translateX(-50%);}
.auth-logo{font-size:2rem;font-weight:800;letter-spacing:-.05em;background:linear-gradient(135deg,var(--blue),var(--violet));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:6px;}
.auth-tagline{font-size:.82rem;color:var(--muted);margin-bottom:36px;text-align:center;}
.auth-tabs{display:flex;background:var(--s1);border-radius:12px;padding:4px;margin-bottom:24px;width:100%;}
.auth-tab{flex:1;padding:10px;border:none;background:transparent;color:var(--muted);font-size:.85rem;font-weight:700;cursor:pointer;border-radius:9px;transition:all .18s;font-family:'Sora',sans-serif;}
.auth-tab.active{background:var(--s2);color:var(--txt);box-shadow:0 2px 8px rgba(0,0,0,.3);}
.auth-field{display:flex;flex-direction:column;gap:6px;margin-bottom:14px;width:100%;}
.auth-label{font-size:.7rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.07em;}
.auth-input{background:var(--s1);border:1.5px solid var(--bdr);border-radius:12px;padding:14px 16px;color:var(--txt);font-size:.95rem;font-weight:500;width:100%;outline:none;transition:border-color .2s;font-family:'Sora',sans-serif;}
.auth-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(91,138,240,.12);}
.auth-input::placeholder{color:var(--dim);}
.auth-btn{background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;font-weight:800;font-size:.95rem;border:none;border-radius:50px;padding:17px;width:100%;cursor:pointer;box-shadow:0 8px 28px rgba(91,138,240,.32);font-family:'Sora',sans-serif;margin-top:4px;}
.auth-err{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:10px;padding:10px 14px;font-size:.8rem;color:var(--red);margin-bottom:12px;text-align:center;display:none;width:100%;}
.auth-divider{display:flex;align-items:center;gap:10px;margin:16px 0;width:100%;}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--bdr);}
.auth-divider span{font-size:.72rem;color:var(--muted);}

/* ── NO QUIZ DATA ── */
.no-data{min-height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 28px;text-align:center;}
.no-data-icon{font-size:3rem;margin-bottom:16px;}
.no-data-title{font-size:1.4rem;font-weight:800;letter-spacing:-.03em;margin-bottom:8px;}
.no-data-sub{font-size:.84rem;color:var(--muted);line-height:1.7;margin-bottom:28px;}

/* ── REGEN BUTTON ── */
.regen-btn{display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(91,138,240,.08);border:1.5px solid rgba(91,138,240,.2);border-radius:50px;padding:12px 20px;font-size:.82rem;font-weight:700;color:var(--blue);cursor:pointer;font-family:'Sora',sans-serif;transition:all .18s;margin:0 20px 16px;}
.regen-btn:hover{background:rgba(91,138,240,.15);}

::-webkit-scrollbar{width:0;}
</style>
</head>
<body>
<div id="app">

  <!-- TOPBAR -->
  <div id="tb">
    <div id="bk" onclick="goBack()">←</div>
    <div class="logo">GetPhysIQ</div>
    <div class="user-avatar" id="avatarBtn" onclick="toggleMenu()" style="display:none"></div>
  </div>

  <!-- USER MENU -->
  <div id="userMenu">
    <div class="menu-item" id="menuName" style="color:var(--muted);font-size:.75rem;cursor:default;pointer-events:none;"></div>
    <div class="menu-sep"></div>
    <div class="menu-item" onclick="toggleMenu();showTab('account')">📋 My Plans</div>
    <div class="menu-item danger" onclick="doLogout()">↩ Log Out</div>
  </div>

  <!-- BOTTOM NAV -->
  <div id="nav">
    <button class="nav-btn on" id="nav-stats" onclick="showTab('stats')">
      <div class="nav-icon">📊</div>
      <div class="nav-label">Stats</div>
    </button>
    <button class="nav-btn" id="nav-workout" onclick="showTab('workout')">
      <div class="nav-icon">💪</div>
      <div class="nav-label">Workout</div>
    </button>
    <button class="nav-btn" id="nav-meal" onclick="showTab('meal')">
      <div class="nav-icon">🥗</div>
      <div class="nav-label">Nutrition</div>
    </button>
    <button class="nav-btn" id="nav-account" onclick="showTab('account')">
      <div class="nav-icon">⚙️</div>
      <div class="nav-label">Account</div>
    </button>
  </div>

  <!-- SCREENS (filled by JS) -->
  <div id="sc-stats"  class="sc in"></div>
  <div id="sc-workout" class="sc"></div>
  <div id="sc-meal"    class="sc"></div>
  <div id="sc-account" class="sc"></div>

</div>

<!-- AUTH WALL -->
<div id="authWall">
  <div class="auth-logo">GetPhysIQ</div>
  <div class="auth-tagline">Sign in to access your plans.</div>
  <div class="auth-tabs">
    <button class="auth-tab active" id="tabLogin" onclick="switchTab('login')">Log In</button>
    <button class="auth-tab" id="tabSignup" onclick="switchTab('signup')">Sign Up</button>
  </div>
  <div class="auth-err" id="authErr"></div>
  <div id="loginForm" style="width:100%">
    <div class="auth-field">
      <div class="auth-label">Email</div>
      <input class="auth-input" type="email" id="loginEmail" placeholder="you@email.com" autocomplete="email"/>
    </div>
    <div class="auth-field">
      <div class="auth-label">Password</div>
      <input class="auth-input" type="password" id="loginPass" placeholder="••••••••" autocomplete="current-password"/>
    </div>
    <button class="auth-btn" onclick="doLogin()">LOG IN →</button>
  </div>
  <div id="signupForm" style="display:none;width:100%">
    <div class="auth-field">
      <div class="auth-label">Full Name</div>
      <input class="auth-input" type="text" id="signupName" placeholder="Your name"/>
    </div>
    <div class="auth-field">
      <div class="auth-label">Email</div>
      <input class="auth-input" type="email" id="signupEmail" placeholder="you@email.com" autocomplete="email"/>
    </div>
    <div class="auth-field">
      <div class="auth-label">Password</div>
      <input class="auth-input" type="password" id="signupPass" placeholder="Min 6 characters" autocomplete="new-password"/>
    </div>
    <button class="auth-btn" onclick="doSignup()">CREATE ACCOUNT →</button>
  </div>
  <div class="auth-divider"><span>already have the app?</span></div>
  <button onclick="window.location.href='index.html'" style="background:none;border:none;color:var(--blue);font-size:.85rem;font-weight:700;cursor:pointer;font-family:'Sora',sans-serif;">← Back to GetPhysIQ</button>
</div>

<script>
// ════════════════════════════════════════
//  LOAD STATE FROM MAIN APP localStorage
// ════════════════════════════════════════
function loadS(){
  try{ return JSON.parse(localStorage.getItem('gp_quiz_state')||'null'); }catch(e){ return null; }
}
function getSession(){ try{ return JSON.parse(localStorage.getItem('gp_session')||'null'); }catch(e){ return null; } }
function saveSession(u){ localStorage.setItem('gp_session', JSON.stringify(u)); }
function clearSession(){ localStorage.removeItem('gp_session'); }
function getActivePlan(){ try{ return JSON.parse(localStorage.getItem('gp_active_plan')||'null'); }catch(e){ return null; } }
function getUsers(){ try{ return JSON.parse(localStorage.getItem('gp_users')||'{}'); }catch(e){ return {}; } }
function saveUsers(u){ localStorage.setItem('gp_users', JSON.stringify(u)); }

var S = loadS() || {
  gender:'male',age:'25-34',build:'medium',dreamBuild:'muscular',
  goals:['lose_fat'],zones:['chest','belly','arms'],
  activity:'moderate',experience:'intermediate',
  height:180,weight:82,goalWeight:75,
  workoutDays:'4',workoutDuration:'45',workoutLocation:['gym'],
  diet:'average',sleep:'7-8',stress:'medium',motivation:'looks'
};

var currentTab = 'stats';
var workoutGenerated = false;
var mealGenerated    = false;

// ════════════════════════════════════════
//  CALCULATIONS
// ════════════════════════════════════════
function calcStats(){
  var h = +S.height||180, w = +S.weight||80, gw = +S.goalWeight||75;
  var bmi = (w/((h/100)**2)).toFixed(1);
  var cat = 'Normal', cc = 'var(--green)';
  if(bmi<18.5){cat='Underweight';cc='var(--blue)';}
  else if(bmi<25){cat='Normal';cc='var(--green)';}
  else if(bmi<30){cat='Overweight';cc='var(--amber)';}
  else{cat='Obese';cc='var(--red)';}
  var ageN = S.age==='18-24'?21:S.age==='25-34'?29:S.age==='35-44'?39:S.age==='45-54'?49:58;
  var bmr = S.gender==='female'
    ? 10*w + 6.25*h - 5*ageN - 161
    : 10*w + 6.25*h - 5*ageN + 5;
  var actMult={sedentary:1.2,light:1.375,moderate:1.55,active:1.725,athlete:1.9};
  var tdee = Math.round(bmr*(actMult[S.activity]||1.55));
  var goalCals = (S.goals||[]).includes('lose_fat') ? tdee-400 : (S.goals||[]).includes('build_muscle') ? tdee+300 : tdee;
  var days = parseInt(S.workoutDays)||3;
  var diff = Math.abs(w-gw);
  var weeks = Math.max(2, Math.round(diff/.5/days*3));
  return {h,w,gw,bmi,cat,cc,tdee,goalCals,weeks};
}

// ════════════════════════════════════════
//  BUILD PROFILE STRING FOR AI
// ════════════════════════════════════════
function buildProfile(){
  var c = calcStats();
  var goalLabels={lose_fat:'lose fat and weight',build_muscle:'build muscle and strength',tone:'get lean and toned',endurance:'improve endurance',confidence:'build confidence'};
  var zoneLabels={belly:'belly/core',chest:'chest/pecs',arms:'arms',back:'back',legs:'legs',glutes:'glutes',shoulders:'shoulders'};
  var expLabels={beginner:'complete beginner',some:'some experience (inconsistent)',intermediate:'intermediate (1-2 years)',advanced:'advanced (3+ years)'};
  var actLabels={sedentary:'sedentary',light:'lightly active',moderate:'moderately active',active:'very active',athlete:'athlete level'};
