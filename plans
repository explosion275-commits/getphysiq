function drawChart(cw, gw, weeks){
  var canvas = document.getElementById('wChart');
  if(!canvas) return;
  var card = canvas.parentElement;
  var W = card.clientWidth - 28;
  var H = Math.round(W*0.52);
  var dpr = window.devicePixelRatio||1;
  canvas.style.width=W+'px'; canvas.style.height=H+'px';
  canvas.width=W*dpr; canvas.height=H*dpr;
  var ctx = canvas.getContext('2d');
  ctx.scale(dpr,dpr);
  var pts = Math.max(8,Math.min(weeks,20));
  var data = [];
  for(var i=0;i<=pts;i++){var t=i/pts,e=1-(1-t)**2.6;data.push(cw+(gw-cw)*e);}
  var mn=Math.min(...data),mx=Math.max(...data);
  var pad_y=(mx-mn)*0.25||3;
  var yMin=mn-pad_y,yMax=mx+pad_y;
  var pad={l:44,r:14,t:16,b:28};
  var cW2=W-pad.l-pad.r,cH=H-pad.t-pad.b;
  var xp=function(i){return pad.l+(i/pts)*cW2;};
  var yp=function(v){return pad.t+(1-(v-yMin)/(yMax-yMin))*cH;};
  for(var i=0;i<=5;i++){
    var y=pad.t+i/5*cH;
    var val=yMax-(yMax-yMin)*i/5;
    ctx.strokeStyle='rgba(255,255,255,.05)';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(W-pad.r,y);ctx.stroke();
    ctx.fillStyle='rgba(255,255,255,.28)';
    ctx.font=Math.max(9,Math.round(W/42))+'px Sora';
    ctx.textAlign='right';
    ctx.fillText(val.toFixed(1),pad.l-5,y+3.5);
  }
  var fg=ctx.createLinearGradient(0,pad.t,0,H);
  fg.addColorStop(0,'rgba(91,138,240,.28)');fg.addColorStop(1,'rgba(91,138,240,0)');
  ctx.beginPath();ctx.moveTo(xp(0),yp(data[0]));
  data.forEach(function(_,i){if(i>0)ctx.lineTo(xp(i),yp(data[i]));});
  ctx.lineTo(xp(pts),H-pad.b);ctx.lineTo(xp(0),H-pad.b);ctx.closePath();
  ctx.fillStyle=fg;ctx.fill();
  var lg=ctx.createLinearGradient(0,0,W,0);
  lg.addColorStop(0,'#5b8af0');lg.addColorStop(1,'#8b5cf6');
  ctx.beginPath();ctx.moveTo(xp(0),yp(data[0]));
  data.forEach(function(_,i){if(i>0)ctx.lineTo(xp(i),yp(data[i]));});
  ctx.strokeStyle=lg;ctx.lineWidth=2.5;ctx.lineJoin='round';ctx.lineCap='round';ctx.stroke();
  if(gw!==cw){
    ctx.setLineDash([5,5]);
    ctx.beginPath();ctx.moveTo(pad.l,yp(gw));ctx.lineTo(W-pad.r,yp(gw));
    ctx.strokeStyle='rgba(16,185,129,.55)';ctx.lineWidth=1.5;ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='#10b981';
    ctx.font='bold '+Math.max(9,Math.round(W/44))+'px Sora';
    ctx.textAlign='left';ctx.fillText('Goal',pad.l+5,yp(gw)-5);
  }
  [0,Math.floor(pts/3),Math.floor(pts*2/3),pts].forEach(function(i){
    if(i<=pts){
      ctx.beginPath();ctx.arc(xp(i),yp(data[i]),4,0,Math.PI*2);
      ctx.fillStyle='#fff';ctx.fill();
      ctx.strokeStyle='#5b8af0';ctx.lineWidth=2;ctx.stroke();
    }
  });
  ctx.fillStyle='rgba(255,255,255,.28)';
  ctx.font=Math.max(9,Math.round(W/44))+'px Sora';
  ctx.textAlign='center';
  var xTicks=Math.min(5,pts);
  for(var i=0;i<=xTicks;i++){
    var idx=Math.round(i/xTicks*pts);
    ctx.fillText('wk'+idx,xp(idx),H-pad.b+14);
  }
}

